# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://state_admin:StateLL2024!@localhost:5432/state_lessons

# Auth mode: 'local' for dev, 'azure' for production
AUTH_MODE=local

# Azure AD (required when AUTH_MODE=azure)
AZURE_AD_TENANT_ID=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_REDIRECT_URI=http://localhost:4000/auth/callback

# Security
SESSION_SECRET=change-this-to-a-random-string
JWT_SECRET=change-this-jwt-secret-in-production
TOKEN_EXPIRY=8h

# Frontend
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
